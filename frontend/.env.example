# Browser'a expose edilir — Directus'un public URL'i
NEXT_PUBLIC_DIRECTUS_URL=https://cms.musteri-a.com

# Server-side only — Coolify iç ağında container adını kullan
# Local dev'de boş bırak → NEXT_PUBLIC_DIRECTUS_URL fallback olarak kullanılır
DIRECTUS_INTERNAL_URL=

# Server-side only — NEXT_PUBLIC_ YAPMA, browser'a sızmaz
DIRECTUS_TOKEN=your-token-here

NEXT_PUBLIC_SITE_URL=https://musteri-a.com
RESEND_API_KEY=re_xxx
NEXT_PUBLIC_CDN_URL=https://cms.musteri-a.com/assets

# Dijital Kartvizit Modu
# Sadece kartvizit müşterileri için Coolify'da true yap
# Siteli müşterilerde bu satır olmaz veya false kalır
CARD_ONLY=false
